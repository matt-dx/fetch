@code {
    [Parameter] public ProgressReporter Progress { get; set; } = default!;

    private static string BuildBar(double progress, int width = 40)
    {
        var filled = (int)Math.Min(progress * width, width);
        var empty = width - filled;
        return $"[{new string('\u2588', filled)}{new string(' ', empty)}]";
    }
}

<Columns>
    <Panel Border="BoxBorder.None" Width="44">
        <Align Horizontal="HorizontalAlignment.Left">
            <Markup Content="@BuildBar(Progress.AssemblyProgress)" Foreground="@Color.Green" />
        </Align>
    </Panel>
    <Panel Border="BoxBorder.None" Width="11">
        <Align Horizontal="HorizontalAlignment.Right">
            <Markup Content="@($"{Progress.AssemblyProgress * 100,5:F1}%")" />
        </Align>
    </Panel>
    <Panel Border="BoxBorder.None" Width="20">
        <Markup Content="@($"Chunks: {Progress.AssembledChunks}/{Progress.TotalChunks}")" />
    </Panel>
</Columns>
